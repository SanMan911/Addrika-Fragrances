{
  "version": 2,
  "framework": "create-react-app",
  "regions": ["bom1"],
  "buildCommand": "yarn build",
  "outputDirectory": "build",
  "build": {
    "env": {
      "CI": "false",
      "DISABLE_ESLINT_PLUGIN": "true",
      "REACT_APP_BACKEND_URL": "https://auth-preview-23.preview.emergentagent.com"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://auth-preview-23.preview.emergentagent.com/api/:path*" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

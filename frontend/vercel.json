{
  "version": 2,
  "framework": "create-react-app",
  "regions": ["bom1"],
  "build": {
    "env": {
      "CI": "false",
      "DISABLE_ESLINT_PLUGIN": "true"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://seo-next-migration.preview.emergentagent.com/api/:path*" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
